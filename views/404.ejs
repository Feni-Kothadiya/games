<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <link rel="manifest" href="/public/manifest.json">
    <link rel="icon" href="/public/images/doradora-games-logo.ico">

    <title>Page Not Found - Dora Dora Play</title>

    <meta name="description"
        content="The page you are looking for was not found on Dora Dora Play. Play free online games!">
    <meta property="og:title" content="Page Not Found - Dora Dora Play">
    <meta property="og:url" content="https://doradoraplay.com/">
    <meta property="og:description"
        content="The page you are looking for was not found. Play free online games on Dora Dora Play!">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="Page Not Found - Dora Dora Play">
    <meta name="twitter:description" content="The page you are looking for was not found.">
    <meta name="twitter:image" content="https://doradoraplay.com/images/dora dora_meta.png">

    <link rel="preload" as="style" href="/public/content/themes/default/style/home.css" />
    <%- include('partials/head') %>
        <link rel="stylesheet" type="text/css" href="/public/content/themes/default/style/home.css" />
</head>

<body id="page-top" class="page-home">
    <span class="search-trans-bg"></span>
    <noscript>
        <iframe src="https://www.googletagmanager.com/ns.html?id=G-XSESV3SD4Z" height="0" width="0"
            style="display:none;visibility:hidden"></iframe>
    </noscript>

    <div class="app-wrapper">
        <%- include('partials/nav') %>

            <div class="app-shell">
                <%- include('partials/sidebar') %>

                    <main class="app-main">
                        <%- include('partials/breadcrumb', { crumbs: [{ label: 'Home' , href: '/' }, {
                            label: 'Page Not Found' }] }) %>

                            <section class="home-hero" style="text-align: center; padding: 60px 20px;">
                                <h1
                                    style="font-size: clamp(48px, 8vw, 84px); color: var(--ui-highlight); margin-bottom: 20px;">
                                    404</h1>
                                <h2
                                    style="font-size: clamp(24px, 4vw, 36px); color: var(--ui-text); margin-bottom: 20px;">
                                    Oops! Page Not Found</h2>
                                <p
                                    style="color: var(--ui-text-muted); font-size: 16px; max-width: 500px; margin: 0 auto 30px;">
                                    The page you are looking for might have been removed, had its name changed, or is
                                    temporarily unavailable.
                                </p>
                                <a href="/" class="home-hero__game-cta">Go Back Home</a>
                            </section>

                            <% if (typeof data !=='undefined' && data && data.length) { %>
                                <section class="home-games-section" style="margin-top: 20px;">
                                    <h2 class="home-section-title">Check Out These Games Instead</h2>
                                    <div class="home-games-grid">
                                        <% data.slice(0, 18).forEach(function(item) { %>
                                            <% var sizeClass=item.size===3 ? 'home-game-card--large' : (item.size===2
                                                ? 'home-game-card--medium' : 'home-game-card--small' ); %>
                                                <a href="<%= item.pagelink.replace(/ /g,'_') %>"
                                                    class="home-game-card <%= sizeClass %>">
                                                    <span class="home-game-card-overlay"></span>
                                                    <span class="home-game-card-media">
                                                        <img src="<%= item.thumb %>" alt="<%= item.name %>" width="350"
                                                            height="350" loading="lazy" decoding="async">
                                                    </span>
                                                    <span class="home-game-card-title">
                                                        <%= item.name %>
                                                    </span>
                                                </a>
                                                <% }); %>
                                    </div>
                                </section>
                                <% } %>
                    </main>
            </div>
    </div>

    <%- include('partials/footer') %>
</body>

</html>